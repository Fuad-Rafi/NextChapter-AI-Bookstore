# Backend API base URL for frontend (set this in Vercel frontend project)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Backend URL for the optional Vercel API proxy route
BACKEND_URL=http://localhost:5000

# Public site URL for sitemap and metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Optional comma-separated image hostnames for Next.js optimization
# Example: images.unsplash.com,cdn.example.com
NEXT_PUBLIC_IMAGE_HOSTS=
