# Server Configuration
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Database
MONGODB_URL=mongodb://localhost:27017/blog

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Admin Credentials
# For ADMIN_PASSWORD, use a bcrypt hash. Generate one with:
# node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('your-password', 10).then(console.log);"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=$2a$10$N9qo2nJ2y1YJ5F5Jc5FJ5u5J5J5J5J5J5J5J5J5J5J5J5J5J5J5J5

# Qdrant (optional - enable for vector DB retrieval)
QDRANT_ENABLED=0
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=books
QDRANT_SEARCH_LIMIT=40
